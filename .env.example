# ============================================================================
#  fragments — configuration
#  Copie ce fichier en .env  ( cp .env.example .env )  puis remplis les valeurs.
#  NE COMMIT JAMAIS le fichier .env (il contient des secrets).
#
#  Le même fichier alimente le script de sauvegarde (upload-to-s3.sh) et le
#  CLI/serveur fragments.
# ============================================================================

# --- Identifiants S3 --------------------------------------------------------
# Fonctionne avec n'importe quel stockage objet compatible S3
# (OVH, AWS, Scaleway, MinIO, ...). Crée une clé d'accès chez ton fournisseur.
S3_ACCESS_KEY_ID=ta_cle_access
S3_SECRET_ACCESS_KEY=ta_cle_secrete

# --- Cible -----------------------------------------------------------------
S3_BUCKET=mes-photos

# Région / endpoint de ton fournisseur.
#   Exemple OVH        : région bhs, endpoint s3.bhs.io.cloud.ovh.net
#   Exemple AWS        : région eu-west-1, endpoint s3.eu-west-1.amazonaws.com
#   MinIO / auto-hébergé : mets S3_FORCE_PATH_STYLE=true plus bas
S3_REGION=bhs
S3_ENDPOINT=s3.bhs.io.cloud.ovh.net

# --- Options (facultatif) --------------------------------------------------
# Sous-dossier dans le bucket (vide = racine du bucket).
DEST_PREFIX=

# Dossier à sauvegarder (par défaut : le dossier où se trouve le script).
# SRC_DIR=/chemin/vers/tes/photos/DCIM

# ACL des objets. Laisse "private". Vide-la (S3_ACL=) si ton fournisseur
# refuse les ACL à l'upload.
# S3_ACL=private

# Adressage path-style (nécessaire pour MinIO et certains fournisseurs).
# S3_FORCE_PATH_STYLE=true

# ============================================================================
#  Serveur web  (fragments serve)
# ============================================================================
# Mot de passe unique de connexion (OBLIGATOIRE pour `serve`).
FRAGMENTS_PASSWORD=change-moi

# Clé secrète HMAC pour signer les cookies de session. Mets une longue chaîne
# aléatoire ET STABLE : si elle change (ou est absente, une est générée à chaque
# démarrage), toutes les sessions sont invalidées (il faut se reconnecter).
#   openssl rand -base64 48
# FRAGMENTS_SECRET=

# Adresse d'écoute (défaut :8080). Surchargée par le flag -addr.
# FRAGMENTS_ADDR=:8080

# Mettre "true" derrière HTTPS (active le flag Secure des cookies). Laisser vide
# en local (http://localhost).
# FRAGMENTS_SECURE=

# Durée de vie d'une session en jours (défaut 30).
# FRAGMENTS_SESSION_DAYS=30

# IMPORTANT derrière un reverse-proxy (Caddy/nginx) : liste d'IP/CIDR de
# confiance pour X-Forwarded-For. Sans ça, toutes les IP clientes deviennent
# celle du proxy (le rate-limit de login les regrouperait). En local /
# exposition directe : vide.
# FRAGMENTS_TRUSTED_PROXIES=127.0.0.1

# Concurrence du pool de workers (défaut 2 ; 2-4 sur un petit VPS).
# FRAGMENTS_WORKERS=2

# Resampler de miniatures plus léger (ApproxBiLinear) si le CPU est juste.
# FRAGMENTS_FAST_THUMBS=true
